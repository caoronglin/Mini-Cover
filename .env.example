# Mini-Cover 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ============================================
# 基础配置
# ============================================
NODE_ENV=production
VITE_APP_TITLE=Mini Cover - 封面生成器
VITE_APP_VERSION=1.0.0

# ============================================
# Bing搜索API配置
# ============================================
# 从 https://www.microsoft.com/en-us/bing/apis/bing-web-search-api 获取
VITE_BING_API_KEY=your_bing_api_key_here
VITE_BING_API_URL=https://api.bing.microsoft.com/v7.0

# ============================================
# 阿里云ESA配置
# ============================================
ESA_API_KEY=your_esa_api_key
ESA_NAMESPACE_ID=your_namespace_id
ESA_KV_NAMESPACE=mini-cover-kv
ESA_CACHE_TTL=3600

# ============================================
# 腾讯云EdgeOne配置
# ============================================
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_EDGEONE_ZONE_ID=your_zone_id
EO_KV_NAMESPACE_ID=your_kv_namespace_id

# ============================================
# Cloudflare配置
# ============================================
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ZONE_ID=your_zone_id
KV_NAMESPACE_ID=your_kv_namespace_id
R2_BUCKET_NAME=mini-cover-images

# ============================================
# 图片处理配置
# ============================================
IMAGE_MAX_SIZE=10485760
IMAGE_ALLOWED_TYPES=jpg,jpeg,png,webp,gif
IMAGE_QUALITY=85
IMAGE_THUMB_SIZE=300

# ============================================
# 缓存配置
# ============================================
CACHE_TTL=3600
CACHE_STALE_WHILE_REVALIDATE=86400
CACHE_STATIC_MAX_AGE=31536000

# ============================================
# 功能开关
# ============================================
ENABLE_SEARCH=true
ENABLE_IMAGE_PROCESSING=true
ENABLE_COVER_GENERATION=true
ENABLE_AI_FEATURES=false

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
